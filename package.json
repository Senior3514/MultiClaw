{
  "name": "multiclaw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generate a full AI company around any product.",
  "bin": {
    "multiclaw": "./bin/multiclaw.js"
  },
  "scripts": {
    "init": "node ./bin/multiclaw.js init",
    "example": "node ./bin/multiclaw.js init --demo",
    "setup": "node ./bin/multiclaw.js setup",
    "start": "node ./bin/multiclaw.js start",
    "dev": "node ./bin/multiclaw.js dev",
    "stop": "node ./bin/multiclaw.js stop",
    "status": "node ./bin/multiclaw.js status",
    "demo:router": "node ./src/demo/router-demo.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  }
}
